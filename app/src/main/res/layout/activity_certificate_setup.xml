<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/background">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="HTTPS Inspection Setup"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:titleTextColor="?attr/primaryTextColor" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title explainer -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HTTPS FILTERING"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="?attr/colorPrimary"
                android:letterSpacing="0.08"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp" />

            <!-- Core Explainer Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="What is a CA Certificate?"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="?attr/primaryTextColor"
                        android:layout_marginBottom="8dp" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="To block advertisements and cosmetic layout elements inside HTTPS web pages, RethinkDNS needs to decrypt secure browser connections using a dynamically generated local Certificate Authority (Root CA).\n\nWithout installing this certificate into your system's User credentials store, web browsers will reject all connections intercepted by the local filtering proxy."
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:lineSpacingMultiplier="1.2" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Secure & Warning Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Security &amp; Privacy Guaranteed"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="?attr/primaryTextColor"
                        android:layout_marginBottom="8dp" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• Absolute Local Privacy: The Root CA private key is generated and stored securely in your device's Android Keystore. It NEVER leaves your device.\n\n• Warning Is Normal: When installed, Android (especially Android 11+) may display a 'Network may be monitored' warning. This is NORMAL because you are trusting a user-installed CA to filter your local browsing traffic."
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:lineSpacingMultiplier="1.2" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Certificate Setup / Flow Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Certificate Status"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="?attr/primaryTextColor" />

                        <!-- Installation Badge -->
                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_install_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚠️ NOT INSTALLED"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:textColor="#D32F2F"
                            android:paddingStart="8dp"
                            android:paddingTop="4dp"
                            android:paddingEnd="8dp"
                            android:paddingBottom="4dp"
                            android:background="@drawable/badge_bg_red" />
                    </LinearLayout>

                    <!-- Loading Indicator for Key Gen -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress_gen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:indeterminate="true"
                        android:visibility="gone" />

                    <!-- Generate Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_generate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Generate CA Certificate"
                        android:layout_marginBottom="12dp"
                        app:cornerRadius="8dp" />

                    <!-- Save CA Certificate Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_install"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Save CA Certificate to Downloads"
                        android:enabled="false"
                        app:cornerRadius="8dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Manual Installation Instructions Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_instructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="How to Install Certificate"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="?attr/primaryTextColor"
                        android:layout_marginBottom="8dp" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. Tap 'Save CA Certificate to Downloads' above to save the file 'rethinkdns_ca.pem'.\n\n2. Open your device's Settings app.\n\n3. In the Settings search bar, search for 'CA certificate'.\n   (Or go to: Settings -> Security -> More security settings (or Encryption &amp; credentials) -> Install a certificate -> CA certificate)\n\n4. Confirm when warned with 'Install anyway' and authenticate.\n\n5. Select the saved file 'rethinkdns_ca.pem' from your Downloads folder."
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:lineSpacingMultiplier="1.2" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Toggle Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginEnd="16dp">

                            <androidx.appcompat.widget.AppCompatTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Enable HTTPS Inspection"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:textColor="?attr/primaryTextColor" />

                            <androidx.appcompat.widget.AppCompatTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Intercept secure browser traffic to block ads, scripts, and inject cosmetic filters."
                                android:textSize="12sp"
                                android:textColor="?android:attr/textColorSecondary"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_https_inspection"
                            style="@style/CustomWidget.Material3.CompoundButton.MaterialSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:enabled="false" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
